generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Prospect {
  id              Int          @id @default(autoincrement())
  businessName    String
  ownerName       String?
  category        String
  city            String
  phone           String?
  email           String?
  website         String?
  instagram       String?
  status          String       @default("DA_CONTATTARE")
  potential       String       @default("MEDIO")
  websiteStatus   String       @default("ASSENTE")
  socialStatus    String       @default("SCARSO")
  issues          String?
  opportunities   String?
  notes           String?
  lastContact     DateTime?
  nextFollowUp    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  attachments     Attachment[]
  activities      Activity[]
}

model Attachment {
  id           Int      @id @default(autoincrement())
  prospectId   Int
  prospect     Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  storagePath  String
  mimeType     String
  size         Int
  category     String   @default("ALTRO")
  createdAt    DateTime @default(now())
}

model Activity {
  id          Int      @id @default(autoincrement())
  prospectId  Int
  prospect    Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type        String
  date        DateTime @default(now())
  summary     String
  outcome     String?
  nextAction  String?
  createdAt   DateTime @default(now())
}

model SpesaOperativa {
  id              Int       @id @default(autoincrement())
  nome            String
  categoria       String
  importo         Float
  valuta          String    @default("EUR")
  frequenza       String
  prossimoRinnovo DateTime?
  rinnovoAuto     Boolean   @default(false)
  note            String?
  attivo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
